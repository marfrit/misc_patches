From: Claude Code <noreply@anthropic.com>
Subject: [PATCH] video: rockchip: Fix eDP boot hang on CoolPi CM5 GenBook

The RK3588 eDP display pipeline requires:
1. Power domains enabled for VOP (PD_VOP) and eDP/VO1 (PD_VO1)
2. force-hpd flag for internal eDP panels (no HPD signal)
3. PHY reference and APB clocks enabled before register access
4. Proper clock parent assignment for VOP ACLK
5. Abort on PHY poll timeout instead of continuing with dead hardware

Without these, U-Boot hangs during video probe with no serial output,
because accessing powered-off domain registers locks the AXI bus.

Analysis based on comparing working OEM CoolPi U-Boot DTS (which displays
a logo on eDP) with the broken mainline patches.

WARNING: UNTESTED - created by code analysis and OEM DTS comparison only.

Signed-off-by: Claude Code <noreply@anthropic.com>
---

--- a/drivers/video/rockchip/rk3588_vop2.c
+++ b/drivers/video/rockchip/rk3588_vop2.c
@@ -9,6 +9,7 @@
 #include <clk.h>
 #include <display.h>
 #include <dm.h>
+#include <power-domain.h>
 #include <dm/device_compat.h>
 
 static int rk3588_vop2_probe(struct udevice *dev)
@@ -16,8 +17,22 @@
 	struct video_uc_plat *plat = dev_get_uclass_plat(dev);
 	struct rk3588_vop2_priv *priv = dev_get_priv(dev);
 	struct udevice *syscon;
+	struct power_domain pd;
 	int ret;
 
 	if (!(gd->flags & GD_FLG_RELOC))
 		return 0;
 
+	/*
+	 * CRITICAL: Enable VOP power domain BEFORE any register access.
+	 * VOP2 is in PD_VOP (0x18), eDP/HDPTX are in PD_VO1 (0x1A).
+	 * Accessing registers in a powered-off domain hangs the AXI bus
+	 * with no serial output - the board appears completely dead.
+	 */
+	ret = power_domain_get(dev, &pd);
+	if (!ret) {
+		ret = power_domain_on(&pd);
+		if (ret) {
+			dev_err(dev, "VOP2: failed to enable power domain: %d\n", ret);
+			return ret;
+		}
+	}
+
 	priv->regs = dev_read_addr_ptr(dev);

--- a/drivers/phy/rockchip/phy-rockchip-samsung-hdptx.c
+++ b/drivers/phy/rockchip/phy-rockchip-samsung-hdptx.c
@@ -10,6 +10,7 @@
 #include <clk.h>
 #include <dm.h>
 #include <dm/device_compat.h>
+#include <power-domain.h>
 #include <generic-phy.h>
 
 /* In rockchip_hdptx_phy_power_on(), abort on poll timeout */
@@ -547,7 +548,7 @@
 	if (ret) {
 		dev_err(hdptx->dev, "timeout waiting for phy_rdy\n");
-		/* continue anyway */
+		return ret;
 	}
 
@@ -697,7 +698,7 @@
 	if (ret) {
 		dev_err(hdptx->dev, "timeout waiting for pll_lock_done\n");
-		/* continue anyway */
+		return ret;
 	}
 
@@ -946,7 +947,7 @@
 	if (ret) {
 		dev_err(hdptx->dev, "timeout waiting for sb_rdy\n");
-		/* continue anyway */
+		return ret;
 	}
 
 /* In rockchip_hdptx_phy_probe(), add power domain and clock enables */
@@ -1043,6 +1044,8 @@
 static int rockchip_hdptx_phy_probe(struct udevice *dev)
 {
 	struct rockchip_hdptx_phy *hdptx = dev_get_priv(dev);
+	struct power_domain pd;
+	struct clk ref_clk, apb_clk;
 	int ret;
 
+	/* Enable power domain */
+	ret = power_domain_get(dev, &pd);
+	if (!ret)
+		power_domain_on(&pd);
+
+	/* Enable reference and APB clocks (required before any PHY register access) */
+	ret = clk_get_by_name(dev, "ref", &ref_clk);
+	if (!ret)
+		clk_enable(&ref_clk);
+	ret = clk_get_by_name(dev, "apb", &apb_clk);
+	if (!ret)
+		clk_enable(&apb_clk);
+
 	ret = regmap_init_mem(dev_ofnode(dev), &hdptx->regmap);

--- a/arch/arm/dts/rk3588-coolpi-cm5-genbook-u-boot.dtsi
+++ b/arch/arm/dts/rk3588-coolpi-cm5-genbook-u-boot.dtsi
@@ -21,6 +21,10 @@
 /* eDP display pipeline */
 &edp1 {
 	status = "okay";
+	/*
+	 * force-hpd: Internal eDP panels have no hot-plug detect signal.
+	 * Without this, the eDP driver polls HPD forever and hangs boot.
+	 * The OEM CoolPi U-Boot DTS has this flag set.
+	 */
+	force-hpd;
 	rockchip,panel = <&edp_panel>;
 
 	aux-bus {
@@ -33,8 +37,21 @@
 &hdptxphy1 {
 	status = "okay";
+	bootph-all;
 };
 
 &vop {
 	status = "okay";
+	bootph-all;
+	/*
+	 * Clock parent assignment from OEM DTS.
+	 * Sets CPLL as the VOP ACLK parent.
+	 * Without this, VOP2 may use wrong clock source.
+	 */
+	assigned-clocks = <&cru ACLK_VOP>;
+	assigned-clock-parents = <&cru PLL_CPLL>;
+};
+
+/* PMU reference needed by VOP2 driver */
+&pmu1grf {
+	bootph-all;
 };
