 	  Apple-specific HID-over-SPI protocol.
 
+config HID_I2C_KEYBOARD
+	bool "HID-over-I2C keyboard support"
+	depends on DM_KEYBOARD && DM_I2C
+	select INPUT
+	help
+	  Enable support for keyboards connected via the HID-over-I2C
+	  protocol (Microsoft spec v1.0). This is used by many laptop
+	  keyboards including those on Rockchip-based laptops.
+
