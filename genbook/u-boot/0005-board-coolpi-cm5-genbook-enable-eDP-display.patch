diff --git a/arch/arm/dts/rk3588-coolpi-cm5-genbook-u-boot.dtsi b/arch/arm/dts/rk3588-coolpi-cm5-genbook-u-boot.dtsi
index 5a3073d6e7f..23b086b747d 100644
--- a/arch/arm/dts/rk3588-coolpi-cm5-genbook-u-boot.dtsi
+++ b/arch/arm/dts/rk3588-coolpi-cm5-genbook-u-boot.dtsi
@@ -18,3 +18,31 @@
 &usb_host1_xhci {
 	snps,dis_u3_susphy_quirk;
 };
+
+/* Internal keyboard on I2C5 */
+&i2c5 {
+	bootph-all;
+
+	touchpad@2c {
+		bootph-all;
+	};
+};
+
+/* eDP display pipeline */
+&edp1 {
+	rockchip,panel = <&edp_panel>;
+
+	aux-bus {
+		edp_panel: panel {
+			compatible = "edp-panel";
+		};
+	};
+};
+
+&hdptxphy1 {
+	status = "okay";
+};
+
+&vop {
+	status = "okay";
+};
